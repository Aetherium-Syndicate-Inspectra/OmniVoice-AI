{
  "name": "omnivoice-ai",
  "version": "0.1.0",
  "description": "OmniVoice AI - AI voice agent platform for automated e-commerce call handling and sales",
  "private": true,
  "main": "src/app.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "build": "echo \"No build step configured\"",
    "lint": "eslint src --ext .js || echo \"lint skipped\"",
    "format": "prettier --write .",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "health": "node -e \"console.log('OmniVoice AI service OK')\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "eslint": "^9.9.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3"
  },
  "keywords": [
    "ai",
    "voice-agent",
    "call-automation",
    "ecommerce",
    "customer-support",
    "sales-bot",
    "omnivoice"
  ],
  "author": "INSPIRAFIRMA",
  "license": "MIT"
}
